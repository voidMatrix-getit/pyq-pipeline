```json
{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "charliermarsh.ruff",
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python",
  "python.analysis.typeCheckingMode": "basic",
  "files.encoding": "utf8",
  "editor.tabSize": 4,
  "editor.rulers": [100],
  "[python]": {
    "editor.formatOnSave": true
  }
}
```

